      class="np-input"
      placeholder="・朝会 9:00~9:30 完了
・設計 10:00~11:30 進行中
・タスク名（時刻なし）"
      role="textbox"
      spellcheck="false"
    />
    <div
      aria-label="ガントチャート"
      class="np-gantt"
      role="region"
    >
      <div
        class="np-gantt-header"
      >
        <span
          class="np-gantt-hour"
          style="left: 0%;"
        >
          6
        </span>
        <span
          class="np-gantt-hour"
          style="left: 11.11111111111111%;"
        >
          8
        </span>
        <span
          class="np-gantt-hour"
          style="left: 22.22222222222222%;"
        >
          10
        </span>
        <span
          class="np-gantt-hour"
          style="left: 33.33333333333333%;"
        >
          12
        </span>
        <span
          class="np-gantt-hour"
          style="left: 44.44444444444444%;"
        >
          14
        </span>
        <span
          class="np-gantt-hour"
          style="left: 55.55555555555556%;"
        >
          16
        </span>
        <span
          class="np-gantt-hour"
          style="left: 66.66666666666666%;"
        >
          18
        </span>
        <span
          class="np-gantt-hour"
          style="left: 77.77777777777779%;"
        >
          20
        </span>
        <span
          class="np-gantt-hour"
          style="left: 88.88888888888889%;"
        >
          22
        </span>
        <span
          class="np-gantt-hour"
          style="left: 100%;"
        >
          24
        </span>
      </div>
      <div
        class="np-gantt-rows"
      >
        <div
          class="np-gantt-empty"
        >
          エントリを入力するとここに表示されます
        </div>
      </div>
    </div>
    <div
      aria-label="サマリ"
      class="np-summary"
      role="region"
    >
      <div
        class="np-group np-group--pending"
      >
        <div
          class="np-group-header"
        >
          未着手
        </div>
        <div
          class="np-group-items"
        >
          <div
            class="np-group-item np-group-item--empty"
          >
            なし
          </div>
        </div>
      </div>
      <div
        class="np-group np-group--in-progress"
      >
        <div
          class="np-group-header"
        >
          進行中
        </div>
        <div
          class="np-group-items"
        >
          <div
            class="np-group-item np-group-item--empty"
          >
            なし
          </div>
        </div>
      </div>
      <div
        class="np-group np-group--completed"
      >
        <div
          class="np-group-header"
        >
          完了
        </div>
        <div
          class="np-group-items"
        >
          <div
            class="np-group-item np-group-item--empty"
          >
            なし
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

