exports[`UI スナップショット > Phantom > ダークモード 1`] = `
<div
  class="ph-root dark"
>
  <header
    class="ph-header"
  >
    <div
      style="display: flex; align-items: center; gap: 10px;"
    >
      <svg
        aria-hidden="true"
        class="lucide lucide-wand-sparkles"
        fill="none"
        height="22"
        stroke="white"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="22"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"
        />
        <path
          d="m14 7 3 3"
        />
        <path
          d="M5 6v4"
        />
        <path
          d="M19 14v4"
        />
        <path
          d="M10 2v2"
        />
        <path
          d="M7 8H3"
        />
        <path
          d="M21 16h-4"
        />
        <path
          d="M11 3H9"
        />
      </svg>
      <div>
        <div
          class="ph-logo"
        >
          PHANTOM
        </div>
        <div
          class="ph-subtitle"
        >
          text mask & transform engine
        </div>
      </div>
    </div>
  </header>
  <div
    class="ph-main"
  >
    <div
      class="ph-panel"
    >
      <div
        class="ph-panel-label"
      >
        INPUT
      </div>
      <textarea
        class="ph-input"
        placeholder="テキストを入力..."
      />
    </div>
    <div
      class="ph-panel"
    >
      <div
        class="ph-panel-label"
      >
        OUTPUT
      </div>
      <div
        class="ph-output-wrap"
      >
        <div
          class="ph-output"
        />
        <button
          class="ph-copy-btn"
        >
          コピー
        </button>
      </div>
    </div>
    <div
      class="ph-rules-panel"
    >
      <div
        class="ph-tabs"
      >
        <button
          class="ph-tab active"
        >
          置換
        </button>
        <button
          class="ph-tab"
        >
          ランダム
        </button>
      </div>
      <div
        class="ph-pair-row"
      >
        <input
          class="ph-field"
          placeholder="変換前"
          value=""
        />
        <span
          class="ph-arrow"
        >
          →
        </span>
        <input
          class="ph-field"
          placeholder="変換後"
          value=""
        />
        <button
          aria-label="ペアを削除"
          class="ph-del-btn"
        >
          ×
        </button>
      </div>
      <button
        class="ph-add-btn"
      >
        ＋ ペアを追加
      </button>
    </div>
  </div>
</div>
`;

